# Secrets — never commit
.env
*.env
# NOTE: pipeline/config.yaml is now TRACKED on purpose (canonical backup; it holds
# no secrets — those live in .env). Edit it via git, not by hand on the VPS.

# Python
.venv/
__pycache__/
*.pyc

# Generated site output and working data
site/output/
pipeline/.cache/
pipeline/drafts/
pipeline/state/
*.eml

# Manual flyer drops: track the folder skeleton (README + .gitkeep), never the
# uploaded PDFs/images or the archived copies.
/drops/**
!/drops/**/
!/drops/README.md
!/drops/**/.gitkeep

# OS / editor
.DS_Store

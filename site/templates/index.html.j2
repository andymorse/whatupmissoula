{% extends "base.html.j2" %}
{% block title %}What's Up Missoula — Best Grocery Deals, Week of {{ report.week_of }}{% endblock %}
{% block body %}
<header class="hero">
  <div class="container">
    <div class="brand">
      <img src="/static/img/mark.png" alt="What's Up Missoula" onerror="this.style.display='none'">
      <span>What's Up Missoula</span>
    </div>
    <span class="label">Missoula grocery deals · Week of {{ report.week_of }}</span>
    <h1>This week's <em>best deals</em>, in one place.</h1>
    {% if report.generated_note %}<p class="sub">{{ report.generated_note }}</p>{% endif %}
  </div>
</header>

{% if report.best_store %}
<div class="container">
  <div class="best">
    <span class="label">Best store this week</span>
    <h2>{{ report.best_store.name }}</h2>
    <p>{{ report.best_store.reason }}</p>
  </div>
</div>
{% endif %}

{% if report.top_steals %}
{% set has_editor_pick = report.top_steals|selectattr('watchlist_hit')|selectattr('watchlist_source','equalto','mine')|list|length > 0 %}
{% set has_wum_rec = report.top_steals|selectattr('watchlist_hit')|selectattr('watchlist_source','equalto','ai')|list|length > 0 %}
<section class="section">
  <div class="container">
    <span class="label">Don't miss</span>
    <h2>Top steals across town</h2>
    <p class="order-note">{% if has_editor_pick or has_wum_rec %}Our picks first, then{% else %}Ranked by{% endif %} best dollar value across every store — not by store.</p>
    {% if has_editor_pick or has_wum_rec %}
    <p class="disclaimer">{% if has_editor_pick %}An <strong>★ Editor's pick</strong> is a personal favorite from the site owner. {% endif %}{% if has_wum_rec %}A <strong>WUM Recommendation</strong> is a household staple we think is worth grabbing when it's on sale.{% endif %}</p>
    {% endif %}
    <div class="steals" style="margin-top:24px">
      {% for s in report.top_steals %}
      {% set s_pick = s.watchlist_hit and s.watchlist_source == 'mine' %}
      {% set s_rec = s.watchlist_hit and s.watchlist_source == 'ai' %}
      <div class="steal{% if s_pick %} steal-pick{% elif s_rec %} steal-rec{% endif %}">
        {% if s_pick %}
        <div class="editor-pick" title="Hand-picked by the site owner">★ Editor's pick</div>
        {% elif s_rec %}
        <div class="wum-rec" title="A What's Up Missoula recommendation — a staple worth grabbing on sale">WUM Recommendation</div>
        {% endif %}
        <div class="store">{{ s.store }}</div>
        <div class="item">{{ s.item }}</div>
        {% if s.sale_price is not none %}<div class="price">${{ '%.2f'|format(s.sale_price) }}</div>{% endif %}
        {% if s.unit and s.unit_price is not none %}<div class="unit">{{ '%.2f'|format(s.unit_price) }} {{ s.unit }}</div>{% endif %}
        {% set thru = store_dates.get(s.store) %}
        {% if thru %}<div class="steal-dates">through {{ thru|prettydate }}</div>{% endif %}
      </div>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

<section class="section" style="background:var(--warm-white)">
  <div class="container">
    <span class="label">Store by store</span>
    <h2>Every deal, by store</h2>
    <div style="margin-top:24px">
      {% for store in report.stores %}
      <div class="store-block{% if store.kind == 'bulk_wholesale' %} store-bulk{% endif %}">
        <h3>
          {{ store.name }}
          {% if store.kind == 'bulk_wholesale' %}<span class="store-kind bulk">Bulk / wholesale</span>{% endif %}
        </h3>
        <div class="dates">
          {% if store.valid_from and store.valid_through %}{{ store.valid_from|prettydate }} – {{ store.valid_through|prettydate }}
          {% elif store.valid_through %}Valid through {{ store.valid_through|prettydate }}{% endif %}
          {% if not store.in_scope %}<span class="caveat">not a tracked store</span>{% endif %}
        </div>
        {% if store.kind == 'bulk_wholesale' %}
        <p class="store-note">Restaurant-supply pack sizes — prices are per case, not per unit. Best for big families, freezer-stockers, and side-business cooks.</p>
        {% endif %}
        <table class="deals">
          <thead>
            <tr><th>Item</th><th>Sale</th><th>Reg</th><th class="unit-col">Unit price</th><th>Notes</th></tr>
          </thead>
          <tbody>
            {% for d in store.deals %}
            {% set is_pick = d.watchlist_hit and d.watchlist_source == 'mine' %}
            {% set is_rec = d.watchlist_hit and d.watchlist_source == 'ai' %}
            <tr{% if d.watchlist_hit %} class="watch"{% endif %}>
              <td>
                {{ d.item }}
                {% if is_pick %}
                  <span class="watch-badge watch-mine" title="Editor's pick — hand-picked by the site owner">★ Editor's pick</span>
                {% elif is_rec %}
                  <span class="watch-badge watch-wum" title="A What's Up Missoula recommendation — a staple worth grabbing on sale">WUM Recommendation</span>
                {% endif %}
              </td>
              <td class="sale">{% if d.sale_price is not none %}${{ '%.2f'|format(d.sale_price) }}{% else %}—{% endif %}</td>
              <td>{% if d.regular_price is not none %}<span class="reg">${{ '%.2f'|format(d.regular_price) }}</span>{% endif %}
                  {% if d.percent_off %}<span class="pct">{{ d.percent_off }}% off</span>{% endif %}</td>
              <td class="unit-col">{% if d.unit_price is not none %}{{ '%.2f'|format(d.unit_price) }} {{ d.unit }}{% endif %}</td>
              <td>
                {% if d.requires_loyalty %}<span class="caveat">loyalty</span>{% endif %}
                {% for c in d.caveats %}<span class="caveat">{{ c }}</span>{% endfor %}
              </td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
{% endblock %}

{% extends "base.html.j2" %}
{% block title %}What's Up Missoula — Best Grocery Deals, Week of {{ report.week_of }}{% endblock %}
{% block body %}
<header class="hero">
  <div class="container">
    <div class="topbar">
      <div class="brand">
        <img src="/static/img/mark.png" alt="What's Up Missoula" onerror="this.style.display='none'">
        <span>What's Up Missoula</span>
      </div>
      <nav class="sitenav">
        <a href="/" class="active">Deals</a>
        <a href="/events/">Events</a>
      </nav>
    </div>
    <span class="label">Missoula grocery deals · Week of {{ report.week_of }}</span>
    <h1>This week's <em>best deals</em>, in one place.</h1>
    {% if report.generated_note %}<p class="sub">{{ report.generated_note }}</p>{% endif %}
    <p class="refresh-note"><span class="dot"></span>Refreshed every Wednesday</p>
    <div class="dealsearch" hidden>
      <svg class="dealsearch-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
      <input type="search" id="deal-search" class="dealsearch-input" autocomplete="off"
             placeholder="Search deals — try &ldquo;chicken&rdquo; or &ldquo;organic&rdquo;"
             aria-label="Search this week's deals">
      <button type="button" id="deal-search-clear" class="dealsearch-clear" aria-label="Clear search" hidden>&times;</button>
    </div>
    <p class="dealsearch-status" id="deal-search-status" role="status" aria-live="polite" hidden></p>
  </div>
</header>

{% if report.best_store %}
<div class="container">
  <div class="best">
    <span class="label">Best store this week</span>
    <h2>{{ report.best_store.name }}</h2>
    <p>{{ report.best_store.reason }}</p>
  </div>
</div>
{% endif %}

{% if report.top_steals %}
{% set has_editor_pick = report.top_steals|selectattr('watchlist_hit')|selectattr('watchlist_source','equalto','mine')|list|length > 0 %}
{% set has_wum_rec = report.top_steals|selectattr('watchlist_hit')|selectattr('watchlist_source','equalto','ai')|list|length > 0 %}
<section class="section">
  <div class="container">
    <span class="label">Don't miss</span>
    <h2>Top steals across town</h2>
    <p class="order-note">{% if has_editor_pick or has_wum_rec %}Our picks first, then{% else %}Ranked by{% endif %} best dollar value across every store — not by store.</p>
    <div class="steals" style="margin-top:24px">
      {% for s in report.top_steals %}
      {% set s_pick = s.watchlist_hit and s.watchlist_source == 'mine' %}
      {% set s_rec = s.watchlist_hit and s.watchlist_source == 'ai' %}
      <div class="steal{% if s_pick %} steal-pick{% elif s_rec %} steal-rec{% endif %}" data-search="{{ (s.item ~ ' ' ~ s.store)|e }}">
        {% if s_pick %}
        <div class="editor-pick" title="A personal favorite of the WUM team">★ Editor's Pick</div>
        {% elif s_rec %}
        <div class="wum-rec" title="A household staple worth grabbing when it's on sale">WUM Pick</div>
        {% endif %}
        <div class="store">{{ s.store }}</div>
        <div class="item">{{ s.item }}</div>
        {% if s.sale_price is not none %}<div class="price">${{ '%.2f'|format(s.sale_price) }}</div>{% endif %}
        {% if s.unit and s.unit_price is not none %}<div class="unit">{{ '%.2f'|format(s.unit_price) }} {{ s.unit }}</div>{% endif %}
        {% set thru = store_dates.get(s.store) %}
        {% if thru %}<div class="steal-dates">through {{ thru|prettydate }}</div>{% endif %}
      </div>
      {% endfor %}
    </div>
    {% if has_editor_pick or has_wum_rec %}
    <div class="pick-legend">
      {% if has_editor_pick %}<p><span class="ed">★ Editor's Pick</span> — a personal favorite of the WUM team.</p>{% endif %}
      {% if has_wum_rec %}<p><span class="wp">WUM Pick</span> — a household staple worth grabbing when it's on sale.</p>{% endif %}
    </div>
    {% endif %}
  </div>
</section>
{% endif %}

<section class="section" style="background:var(--warm-white)">
  <div class="container">
    <span class="label">Store by store</span>
    <h2>Every deal, by store</h2>
    <div style="margin-top:24px">
      {% for store in report.stores %}
      <div class="store-block{% if store.kind == 'bulk_wholesale' %} store-bulk{% endif %}">
        <h3>
          {{ store.name }}
          {% if store.kind == 'bulk_wholesale' %}<span class="store-kind bulk">Bulk / wholesale</span>{% endif %}
        </h3>
        <div class="dates">
          {% if store.valid_from and store.valid_through %}{{ store.valid_from|prettydate }} – {{ store.valid_through|prettydate }}
          {% elif store.valid_through %}Valid through {{ store.valid_through|prettydate }}{% endif %}
          {% if not store.in_scope %}<span class="caveat">not a tracked store</span>{% endif %}
        </div>
        {% if store.kind == 'bulk_wholesale' %}
        <p class="store-note">Restaurant-supply pack sizes — prices are per case, not per unit. Best for big families, freezer-stockers, and side-business cooks.</p>
        {% endif %}
        <table class="deals">
          <thead>
            <tr><th>Item</th><th>Sale</th><th>Reg</th><th class="unit-col">Unit price</th><th>Notes</th></tr>
          </thead>
          <tbody>
            {% for d in store.deals %}
            {% set is_pick = d.watchlist_hit and d.watchlist_source == 'mine' %}
            {% set is_rec = d.watchlist_hit and d.watchlist_source == 'ai' %}
            <tr{% if d.watchlist_hit %} class="watch"{% endif %} data-search="{{ (d.item ~ ' ' ~ (d.caveats|join(' ')) ~ (' loyalty' if d.requires_loyalty else ''))|e }}">
              <td>
                {{ d.item }}
                {% if is_pick %}
                  <span class="watch-badge watch-mine" title="A personal favorite of the WUM team">★ Editor's Pick</span>
                {% elif is_rec %}
                  <span class="watch-badge watch-wum" title="A household staple worth grabbing when it's on sale">WUM Pick</span>
                {% endif %}
              </td>
              <td class="sale">{% if d.sale_price is not none %}${{ '%.2f'|format(d.sale_price) }}{% else %}—{% endif %}</td>
              <td>{% if d.regular_price is not none %}<span class="reg">${{ '%.2f'|format(d.regular_price) }}</span>{% endif %}
                  {% if d.percent_off %}<span class="pct">{{ d.percent_off }}% off</span>{% endif %}</td>
              <td class="unit-col">{% if d.unit_price is not none %}{{ '%.2f'|format(d.unit_price) }} {{ d.unit }}{% endif %}</td>
              <td>
                {% if d.requires_loyalty %}<span class="caveat">loyalty</span>{% endif %}
                {% for c in d.caveats %}<span class="caveat">{{ c }}</span>{% endfor %}
              </td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<script>
(function () {
  var input = document.getElementById('deal-search');
  if (!input) return;
  var wrap   = input.closest('.dealsearch');
  var clear  = document.getElementById('deal-search-clear');
  var status = document.getElementById('deal-search-status');

  var steals        = [].slice.call(document.querySelectorAll('.steal'));
  var stealsWrap    = document.querySelector('.steals');
  var stealsSection = stealsWrap ? stealsWrap.closest('.section') : null;
  var rows          = [].slice.call(document.querySelectorAll('table.deals tbody tr'));
  var storeBlocks   = [].slice.call(document.querySelectorAll('.store-block'));

  // Search is JS-only — reveal it now that it can actually work.
  if (wrap) wrap.hidden = false;

  function hay(el) {
    return (el.getAttribute('data-search') || el.textContent || '').toLowerCase();
  }
  steals.forEach(function (s) { s._hay = hay(s); });
  rows.forEach(function (r) { r._hay = hay(r); });

  function apply() {
    var raw = input.value.trim();
    var q = raw.toLowerCase();
    clear.hidden = raw === '';

    if (!q) {
      steals.forEach(function (s) { s.hidden = false; });
      rows.forEach(function (r) { r.hidden = false; });
      storeBlocks.forEach(function (b) { b.hidden = false; });
      if (stealsSection) stealsSection.hidden = false;
      status.hidden = true;
      return;
    }

    var stealHits = 0;
    steals.forEach(function (s) {
      var hit = s._hay.indexOf(q) !== -1;
      s.hidden = !hit;
      if (hit) stealHits++;
    });
    if (stealsSection) stealsSection.hidden = stealHits === 0;

    var hits = 0;
    rows.forEach(function (r) {
      var hit = r._hay.indexOf(q) !== -1;
      r.hidden = !hit;
      if (hit) hits++;
    });
    storeBlocks.forEach(function (b) {
      b.hidden = b.querySelectorAll('table.deals tbody tr:not([hidden])').length === 0;
    });

    status.hidden = false;
    status.textContent = hits === 0
      ? 'No deals match “' + raw + '”.'
      : hits + (hits === 1 ? ' deal' : ' deals') + ' match “' + raw + '”.';
  }

  input.addEventListener('input', apply);
  clear.addEventListener('click', function () {
    input.value = '';
    apply();
    input.focus();
  });
})();
</script>
{% endblock %}

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% block title %}What's Up Missoula{% endblock %}</title>
  <meta name="description" content="{% block description %}The best grocery deals in Missoula this week, updated every Wednesday.{% endblock %}">
  {%- if base_url %}
  <link rel="canonical" href="{{ base_url }}{% block path %}/{% endblock %}">
  <meta property="og:url" content="{{ base_url }}{{ self.path() }}">
  <meta property="og:image" content="{{ base_url }}/static/img/og-card.jpg">
  <meta name="twitter:card" content="summary_large_image">
  {%- endif %}
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="What's Up Missoula">
  <meta property="og:title" content="{{ self.title() }}">
  <meta property="og:description" content="{{ self.description() }}">
  {%- if jsonld %}
  <script type="application/ld+json">{{ jsonld|tojson }}</script>
  {%- endif %}
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
  <link rel="manifest" href="/site.webmanifest">
  <meta name="theme-color" content="#0a1628">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&family=Open+Sans:wght@400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/static/css/brand.css">
  <script
    src="https://app.rybbit.io/api/script.js"
    data-site-id="bf570e9f1145"
    defer
  ></script>
</head>
<body>
  {% block body %}{% endblock %}
  <script src="/static/js/img-fallback.js" defer></script>
  <footer>
    <div class="container">
      <p>What's Up Missoula — a <a href="https://fractionalit.io">Fractional</a> project.</p>
      <p>Prices are read from public weekly ads and can change — double-check in store.</p>
    </div>
  </footer>
</body>
</html>

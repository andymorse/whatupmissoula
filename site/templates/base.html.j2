<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% block title %}What's Up Missoula{% endblock %}</title>
  <meta name="description" content="The best grocery deals in Missoula this week.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&family=Open+Sans:wght@400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/static/css/brand.css">
</head>
<body>
  {% block body %}{% endblock %}
  <footer>
    <div class="container">
      What's Up Missoula — a <a href="https://fractionalit.io">Fractional</a> project.
      Deals compiled from public weekly store flyers; prices subject to change — verify in store.
    </div>
  </footer>
</body>
</html>

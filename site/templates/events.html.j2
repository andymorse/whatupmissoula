{% extends "base.html.j2" %}
{% block title %}What's Up Missoula — Missoula Events, Week of {{ report.week_of }}{% endblock %}
{% block body %}
<header class="hero">
  <div class="container">
    <div class="topbar">
      <div class="brand">
        <img src="/static/img/mark.png" alt="What's Up Missoula">
        <span>What's Up Missoula</span>
      </div>
      <nav class="sitenav">
        <a href="/">Deals</a>
        <a href="/events/" class="active">Events</a>
      </nav>
    </div>
    <span class="label">Missoula events · Week of {{ report.week_of }}</span>
    <h1>This week in <em>Missoula</em>.</h1>
    {% if report.week_pick %}<p class="sub">{{ report.week_pick }}</p>{% endif %}
    <p class="refresh-note"><span class="dot"></span>Refreshed every Wednesday</p>
    <div class="dealsearch" hidden>
      <svg class="dealsearch-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
      <input type="search" id="event-search" class="dealsearch-input" autocomplete="off"
             placeholder="Search events — try &ldquo;kids&rdquo; or &ldquo;special&rdquo;"
             aria-label="Search this week's events">
      <button type="button" id="event-search-clear" class="dealsearch-clear" aria-label="Clear search" hidden>&times;</button>
    </div>
    <p class="dealsearch-status" id="event-search-status" role="status" aria-live="polite" hidden></p>
    {# Headline filter chips only (Kids / Special Event) to keep the bar tidy —
       format tags like Subtitled/Annex stay clickable on the cards themselves. #}
    {% set ns = namespace(tags=[]) %}
    {% for e in report.events %}{% for t in e.tags %}{% if t not in ns.tags %}{% set ns.tags = ns.tags + [t] %}{% endif %}{% endfor %}{% endfor %}
    {% set labelmap = {'kid-friendly': 'Kids', 'special-event': 'Special Event'} %}
    {% if 'kid-friendly' in ns.tags or 'special-event' in ns.tags %}
    <div class="tagbar" id="event-tagbar" hidden>
      <span class="tagbar-label">Filter</span>
      {% for t in ['kid-friendly', 'special-event'] if t in ns.tags %}
      <button type="button" class="tagchip tagchip-{{ 'kid' if t == 'kid-friendly' else 'special' }}" data-q="{{ t }}">{{ labelmap[t] }}</button>
      {% endfor %}
    </div>
    {% endif %}
  </div>
</header>

{# A grocery "best store" callout doesn't belong on the events page. A future
   editor's-pick-for-events highlight could live here, but not yet. #}
<section class="section">
  <div class="container">
    <span class="label">This week</span>
    <h2>At The Roxy Theater</h2>
    <p class="order-note">Locally programmed at Missoula's nonprofit community cinema. Search &ldquo;kids&rdquo; for family-friendly screenings, or &ldquo;special&rdquo; for one-off events.</p>
    {% if report.events %}
    <div class="events" style="margin-top:24px">
      {% for e in report.events %}
      {% set kid = 'kid-friendly' in e.tags %}
      {% set special = 'special-event' in e.tags %}
      <div class="event" data-search="{{ (e.title ~ ' ' ~ (e.series or '') ~ ' ' ~ (e.tags|join(' ')) ~ ' ' ~ e.venue ~ (' kids family family-friendly' if kid else '') ~ (' festival' if special else ''))|e }}">
        {% if e.image %}<img class="event-img" src="{{ e.image }}" alt="{{ e.title }}" loading="lazy">{% endif %}
        <div class="event-body">
          {% if kid or special or e.tags %}
          <div class="event-badges">
            {% if kid %}<span class="ev-tag kid" data-q="kid-friendly" title="Filter to kids events">Kids</span>{% endif %}
            {% if special %}<span class="ev-tag special" data-q="special-event" title="Filter to special events">Special Event</span>{% endif %}
            {% for t in e.tags if t not in ['kid-friendly', 'special-event'] %}<span class="ev-tag plain" data-q="{{ t }}" title="Filter to {{ t }}">{{ t }}</span>{% endfor %}
          </div>
          {% endif %}
          <h3 class="event-title">{% if e.url %}<a href="{{ e.url }}" target="_blank" rel="noopener">{{ e.title }}</a>{% else %}{{ e.title }}{% endif %}</h3>
          <div class="event-meta">{{ e.venue }}{% if e.runtime_min %} · {{ e.runtime_min }} min{% endif %}</div>
          {% if e.series %}<div class="event-series">{{ e.series }}</div>{% endif %}
          {% if e.showtimes %}
          <div class="event-times">
            {# group by ISO date so a full Wed→Tue week stays in chronological order #}
            {% for d, group in e.showtimes|groupby('date') %}
            <div><span class="day">{{ (group|first).day }}</span> — {{ group|map(attribute='time')|join(' · ') }}</div>
            {% endfor %}
          </div>
          {% endif %}
        </div>
      </div>
      {% endfor %}
    </div>
    {% else %}
    <p class="order-note" style="margin-top:16px">No screenings listed for this week yet — check back Wednesday.</p>
    {% endif %}
  </div>
</section>

<script src="/static/js/event-search.js" defer></script>
{% endblock %}

# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# --- Mailbox (read-only IMAP) ---
# Google Workspace app password for whatupmissoula@fenixtv.net
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=whatupmissoula@fenixtv.net
IMAP_APP_PASSWORD=

# --- AI provider ---
# "claude" (default) or "local" (future)
AI_PROVIDER=claude
ANTHROPIC_API_KEY=
# Model id — see pipeline/config.yaml for default
ANTHROPIC_MODEL=claude-opus-4-7

# --- Notifications (optional) ---
# Where to send the "draft ready, please review" digest
REVIEW_NOTIFY_EMAIL=

# --- Deployment (docker-compose / Caddy) ---
# Public domain Caddy will request a Let's Encrypt cert for and serve. Leave
# blank locally; set on the VPS once DNS points at the box.
WUM_DOMAIN=whatsupmissoula.com
# Email for the ACME account (Let's Encrypt expiry notices).
WUM_TLS_EMAIL=
# UID/GID of the host user that owns this .env and /opt/wum on the VPS.
# Build-baked into the pipeline image so the container can read the mounted
# .env. Defaults to 1000:1000; override if your host wum is e.g. 1001.
WUM_UID=1000
WUM_GID=1000
